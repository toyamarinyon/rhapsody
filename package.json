{
	"name": "rhapsody-workspace",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "pnpm --filter @rhapsody/app dev",
		"build": "pnpm --filter @rhapsody/app build",
		"start": "pnpm --filter @rhapsody/app start",
		"db:migrate": "pnpm --filter @rhapsody/app db:migrate",
		"setup:plan": "pnpm --filter @rhapsody/app setup:plan",
		"setup:status": "pnpm --filter @rhapsody/app setup:status",
		"setup:inspect": "pnpm --filter @rhapsody/app setup:inspect",
		"setup:configure-local": "pnpm --filter @rhapsody/app setup:configure-local",
		"setup:configure-github": "pnpm --filter @rhapsody/app setup:configure-github",
		"setup:configure-deploy": "pnpm --filter @rhapsody/app setup:configure-deploy",
		"setup:deploy-preview": "pnpm --filter @rhapsody/app setup:deploy-preview",
		"setup:smoke-test": "pnpm --filter @rhapsody/app setup:smoke-test",
		"setup:seed-codex": "pnpm --filter @rhapsody/app setup:seed-codex",
		"setup:create-first-issue": "pnpm --filter @rhapsody/app setup:create-first-issue",
		"setup:first-issue": "pnpm --filter @rhapsody/app setup:first-issue",
		"setup:start-attempt": "pnpm --filter @rhapsody/app setup:start-attempt",
		"setup:verify-run": "pnpm --filter @rhapsody/app setup:verify-run",
		"cli:check": "pnpm --filter @toyamarinyon/rhapsody check",
		"cli:smoke": "pnpm --filter @toyamarinyon/rhapsody smoke:setup-help",
		"lint": "pnpm --filter @rhapsody/app lint",
		"test": "pnpm --filter @rhapsody/app test",
		"format:check": "pnpm --filter @rhapsody/app exec biome format ../../README.md ../../AGENTS.md ../../docs ../../package.json ../../pnpm-workspace.yaml ../../biome.json . ../../packages",
		"format": "pnpm --filter @rhapsody/app exec biome format --write ../../README.md ../../AGENTS.md ../../docs ../../package.json ../../pnpm-workspace.yaml ../../biome.json . ../../packages",
		"typecheck": "pnpm --filter @rhapsody/app typecheck"
	}
}
