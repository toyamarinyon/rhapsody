{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"git": {
		"deploymentEnabled": {
			"entire/checkpoints/v1": false
		}
	},
	"crons": [
		{
			"path": "/api/v1/admin/scheduler/tick",
			"schedule": "* * * * *"
		},
		{
			"path": "/api/v1/admin/reconcile",
			"schedule": "*/5 * * * *"
		},
		{
			"path": "/api/v1/admin/codex-chatgpt-credentials/health-check",
			"schedule": "0 */6 * * *"
		}
	]
}
